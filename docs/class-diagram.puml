    + web_server_running: bool
    + web_server_port: Option<u16>
    + last_config_update: Option<DateTime<Utc>>
    + active_sessions: u32
    + health_status: HealthStatus
  }

  enum HealthStatus <<enum>> {
    Healthy
    Warning(String)
    Critical(String)
  }

  AppState *-- ServerStatus
  AppState o-- AuthFramework : Option<Arc>
}

' =============================================================================
' PACKAGE: core (AuthFramework — the root type)
' =============================================================================
package "core (AuthFramework)" #FAFAFA {

  enum AuthResult <<enum>> {
    Success(Box<AuthToken>)
    MfaRequired(Box<MfaChallenge>)
    Failure(String)
  }

  class AuthFramework {
    - config: AuthConfig
    - methods: HashMap<String, AuthMethodEnum>
    - token_manager: TokenManager
    - storage: Arc<dyn AuthStorage>
    - permission_checker: Arc<RwLock<PermissionChecker>>
    - rate_limiter: Option<RateLimiter>
    - mfa_challenges: Arc<RwLock<HashMap<String, MfaChallenge>>>
    - sessions: Arc<RwLock<HashMap<String, SessionData>>>
    - monitoring_manager: Arc<MonitoringManager>
    - audit_manager: Arc<AuditLogger>
    - security_manager: Arc<SecurityManager>
    - distributed_store: Arc<dyn DistributedSessionStore>
    --
    + new(config): Result<Self>
    + new_validated(config): Result<Self>
    + initialize(): Result<()>
    + authenticate(method, credential): Result<AuthResult>
    + validate_token(token): Result<bool>
    + check_permission(token, action, resource): Result<bool>
    + create_auth_token(user_id, scopes, method, client_id): Result<AuthToken>
    + revoke_token(token_id): Result<()>
    + refresh_token(refresh_token): Result<AuthToken>
    + get_user_profile(user_id): Result<UserProfile>
    + register_user(username, password, email): Result<String>
    + delete_user(user_id): Result<()>
    + storage() -> &dyn AuthStorage
    + token_manager() -> &TokenManager
    + set_distributed_store(store)
    + register_method(name, method)
  }

  AuthFramework *-- AuthConfig
  AuthFramework *-- TokenManager
  AuthFramework o--> AuthStorage : Arc<dyn>
  AuthFramework *-- PermissionChecker
  AuthFramework *-- SecurityManager
  AuthFramework *-- AuditLogger
  AuthFramework o--> DistributedSessionStore : Arc<dyn>
  AuthFramework ..> AuthResult : returns
  AuthFramework ..> AuthMethodEnum : dispatches
  AuthResult ..> AuthToken
  AuthResult ..> MfaChallenge
}

' =============================================================================
' CROSS-PACKAGE RELATIONSHIPS
' =============================================================================

' TokenManager used widely
TokenManager ..> JwtClaims
AuthFramework *-- TokenManager

' Storage trait is the central integration point
AuthStorage <|.. MemoryStorage
AuthStorage <|.. RedisStorage
AuthStorage <|.. PostgresStorage
AuthFramework o--> AuthStorage

' AuthorizationService uses AuthStorage indirectly (through role_system)
AuthorizationService ..> AuthStorage : via role_system<S>

' ApiState bridges config to handlers
ApiState o--> AuthFramework
ApiState o--> AuthorizationService

' OAuth2Server (domain) uses storage + token_manager from AuthFramework-adjacent types
OAuth2Server o--> TokenManager
OAuth2Server o--> EnhancedTokenStorage
OAuth2Server ..> UserContext : authenticates

' Server layer uses AuthStorage via ClientRegistry
ClientRegistry o--> AuthStorage
OAuth21Server *-- ServerOAuth2Server
ServerOAuth2Server o--> ClientRegistry

' SessionManager uses SessionStorage
SessionManager ..> SessionStorage : uses

' Security components
SecureMfaService ..> AuthStorage : uses
SecureJwtValidator ..> SecureJwtConfig
TokenExchangeManager o--> SecureJwtValidator

' AuditLogger used by core and session manager
AuditLogger ..> AuditStorageInterface

' DistributedRateLimiter used by ApiState
ApiState o--> DistributedRateLimiter

' ConfigManager produces AuthFrameworkSettings
ConfigManager ..> AuthFrameworkSettings : produces

' AppState (admin) holds framework
AppState o--> AuthFramework

' =============================================================================
' DUPLICATION SUMMARY NOTE
' =============================================================================

note as NDupSummary
  <b>DUPLICATION HOTSPOTS (candidates for consolidation)</b>
  
  1. <b>UserProfile / UserInfo</b> — defined 5+ times:
     providers::UserProfile, api::auth::UserInfo,
     api::users::UserProfile, methods::UserInfo,
     server::oidc::OidcUserInfo
     → Consolidate into one canonical type in providers.rs
  
  2. <b>Permission + Role</b> — defined twice:
     permissions.rs (Role without id/timestamps)
     authorization.rs (Role with id, metadata, timestamps)
     → Merge into authorization.rs version (richer)
  
  3. <b>TokenRequest + TokenResponse</b> — defined twice:
     oauth2_server::TokenRequest (11 fields, username/device_code)
     api::oauth2::ApiTokenRequest (7 fields, API-only)
     → Keep separate but document the split intentionally
  
  4. <b>MfaChallenge</b> — defined twice:
     methods::MfaChallenge (id, type, user_id, expires_at, data)
     security::secure_mfa::MfaChallenge (adds code_hash, attempts)
     → Consider extending one or using composition
  
  5. <b>DeviceInfo</b> — defined 3 times:
     session::DeviceInfo (browser, os, fingerprint, trust)
     audit::DeviceInfo (type, os, browser, is_mobile, resolution)
     security::DeviceFingerprint (hashes: browser, canvas, webgl)
     → Different purposes, but could share a common base
  
  6. <b>SessionState enum</b> — defined twice:
     session::SessionState (Active/Expired/Revoked/Suspended/RequiresMfa/RequiresReauth)
     security::SecureSessionState (same but RequiresRotation + HighRisk)
     → Merge into one place
  
  7. <b>ClientType enum</b> — defined twice:
     oauth2_domain::ClientType (Confidential/Public)
     server_layer::ClientType (Confidential/Public/Device)
     → Use server_layer version everywhere
  
  8. <b>OAuth2 three-layer split</b>:
     - Layer 1: api/oauth2.rs handlers (live, reach into AuthFramework directly)
     - Layer 2: oauth2_server::OAuth2Server (library API, unused by HTTP layer)
     - Layer 3: server::oauth::* (RFC objects, unused by HTTP layer)
     → Either wire layers 2/3 into the API handlers, or remove them
  
  9. <b>ClientConfig vs EnhancedClientCredentials</b>:
     Both represent a registered OAuth client with the same fields.
     ClientConfig is in server_layer, EnhancedClientCredentials in oauth2_domain.
     → Merge into one canonical registered-client type
  
  10. <b>AuthorizationRequest / PushedAuthorizationRequest</b>:
      Defined in oauth2_server, api/oauth_advanced (PARRequest), server/oauth/par
      → Unify into one type; PAR is just AuthorizationRequest + client credentials
end note

@enduml
